# Shared production services
DATABASE_URL=
DATABASE_POOL_MAX=10
REDIS_URL=
LOG_LEVEL=info

# S3 uploads and scoring memos
AWS_REGION=eu-north-1
S3_BUCKET=cap-assessment-prod-sabitkadli
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Scoring worker
SCORING_QUEUE=scoring-runs
SCORING_CONCURRENCY=2
ANTHROPIC_API_KEY=
MEMO_MODEL=claude-sonnet-4-6
OUTBOX_INTERVAL_MS=5000

# AI-first stage grader (runs inside scoring-worker)
STAGE_SCORE_QUEUE=stage-score
SANDBOX_DONE_QUEUE=sandbox-done
GRADER_MODEL=claude-sonnet-4-6
GRADER_CONCURRENCY=4
GRADER_VERIFIER_ENABLED=true
GRADER_SHADOW=true
GRADER_REVIEW_DIVERGENCE_THRESHOLD=15
GRADER_LOW_CONF_THRESHOLD=0.6

# AWS Transcribe for media stages
TRANSCRIBE_POLL_INTERVAL_MS=15000
TRANSCRIBE_TIMEOUT_MS=600000

# Calibration
CALIBRATION_CRON=0 3 * * *
CALIBRATION_MAE_ALERT=8

# Optional ATS integrations
# After filling any provider pair, run:
# pnpm --filter @cap/scoring-worker ats:check
ATS_GREENHOUSE_URL=
ATS_GREENHOUSE_SECRET=
ATS_LEVER_URL=
ATS_LEVER_SECRET=
ATS_WORKDAY_URL=
ATS_WORKDAY_SECRET=

# Sandbox worker
SANDBOX_QUEUE=sandbox-runs
SANDBOX_IMAGE=cap/sandbox:latest
SANDBOX_RUNTIME=runc
SANDBOX_CONCURRENCY=1
SANDBOX_SECCOMP_PATH=
