# Normalize all text files to LF on checkout and commit
* text=auto eol=lf

# Explicit text — force LF (especially important for scripts)
*.ts     text eol=lf
*.tsx    text eol=lf
*.js     text eol=lf
*.json   text eol=lf
*.md     text eol=lf
*.css    text eol=lf
*.yaml   text eol=lf
*.yml    text eol=lf
*.sql    text eol=lf
*.sh     text eol=lf
*.env    text eol=lf
*.env.*  text eol=lf

# Binary — never diff or mangle
*.db     binary
*.db-shm binary
*.db-wal binary
*.gz     binary
*.zst    binary
*.pack   binary
*.png    binary
*.jpg    binary
*.jpeg   binary
*.ico    binary
*.woff   binary
*.woff2  binary
*.ttf    binary
*.otf    binary
