{
  "name": "candidate-assessment-platform",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "node --import tsx --test tests/upload-contract.test.ts tests/migrations.test.ts tests/server-stage-scoring.test.ts tests/ats-signature.test.ts packages/graders/__tests__/reconcile.test.ts apps/scoring-worker/__tests__/grading.test.ts",
    "db:migrate": "pnpm --filter @cap/db migrate",
    "db:migrate:status": "pnpm --filter @cap/db migrate:status",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.15",
    "tsx": "^4.19.2",
    "turbo": "^2.1.3",
    "typescript": "^5.6.3"
  }
}
