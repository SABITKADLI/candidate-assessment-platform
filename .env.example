# ---- database (both apps) ----
DATABASE_URL=postgres://cap:cap@127.0.0.1:5432/cap_dev
DATABASE_POOL_MAX=10

# ---- email (recruiter invite emails) ----
# Sign up at resend.com, add domain sabitkadli.com, verify DNS, create an API key.
# Leave blank in dev — invite URL is logged to console instead.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=CAP Assessments <noreply@sabitkadli.com>
# Webhook signing secret from Resend dashboard → Webhooks → your endpoint → Signing Secret.
# Leave blank in dev to skip signature verification.
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- recruiter / Auth0 ----
# openssl rand -hex 32
AUTH0_SECRET=
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
APP_BASE_URL=http://localhost:3001

# ---- candidate ----
NEXT_PUBLIC_CANDIDATE_BASE_URL=http://localhost:3000
# Secret for the /api/cron/expire endpoint (any random string).
CRON_SECRET=
# Optional shared secret for detailed diagnostics endpoints.
# Set the same value on admin and candidate projects to keep /api/health/queues private.
DIAGNOSTICS_SECRET=

# ---- Turnstile (anti-bot) ----
# Leave both blank in dev for soft-fail (verification skipped, warning logged).
# Prod MUST set both. Get keys from Cloudflare dashboard > Turnstile.
# Site key is public; exposed to the browser via NEXT_PUBLIC_.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ---- MCP server ----
AUTH0_ISSUER=https://your-tenant.us.auth0.com/
AUTH0_AUDIENCE=https://cap.example.com/mcp
REDIS_URL=redis://127.0.0.1:6379
S3_PRESIGN_URL=
MCP_PORT=8787
LOG_LEVEL=info

# ---- sandbox worker ----
SANDBOX_IMAGE=cap/sandbox:latest
SANDBOX_RUNTIME=runsc
SANDBOX_SECCOMP_PATH=/etc/cap/seccomp.json
SANDBOX_QUEUE=sandbox-runs
SANDBOX_CONCURRENCY=2

# ---- S3 uploads and scoring worker ----
SCORING_QUEUE=scoring-runs
SCORING_CONCURRENCY=4
MEMO_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=
STAGE_SCORE_QUEUE=stage-score
SANDBOX_DONE_QUEUE=sandbox-done
GRADER_MODEL=claude-sonnet-4-6
GRADER_CONCURRENCY=4
GRADER_VERIFIER_ENABLED=true
GRADER_SHADOW=true
TRANSCRIBE_POLL_INTERVAL_MS=15000
TRANSCRIBE_TIMEOUT_MS=600000
# Candidate app uses these for browser-to-S3 presigned uploads.
# Scoring worker uses the same bucket for generated memos.
AWS_REGION=eu-north-1
S3_BUCKET=cap-assessment-prod-sabitkadli
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
ATS_GREENHOUSE_URL=
ATS_GREENHOUSE_SECRET=
ATS_LEVER_URL=
ATS_LEVER_SECRET=
ATS_WORKDAY_URL=
ATS_WORKDAY_SECRET=
OUTBOX_INTERVAL_MS=5000
