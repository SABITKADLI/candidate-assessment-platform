{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "DATABASE_URL",
        "AUTH0_SECRET",
        "AUTH0_DOMAIN",
        "AUTH0_CLIENT_ID",
        "AUTH0_CLIENT_SECRET",
        "APP_BASE_URL",
        "AUTH0_ISSUER",
        "AUTH0_AUDIENCE",
        "RESEND_API_KEY",
        "EMAIL_FROM",
        "RESEND_WEBHOOK_SECRET",
        "REDIS_URL",
        "LOG_LEVEL",
        "ANTHROPIC_API_KEY",
        "NEXT_PUBLIC_CANDIDATE_BASE_URL",
        "NEXT_PUBLIC_TURNSTILE_SITE_KEY",
        "TURNSTILE_SECRET_KEY",
        "AWS_REGION",
        "S3_BUCKET",
        "AWS_ACCESS_KEY_ID",
        "AWS_SECRET_ACCESS_KEY",
        "UPLOAD_DIR",
        "CRON_SECRET",
        "SCORING_QUEUE",
        "SCORING_CONCURRENCY",
        "STAGE_SCORE_QUEUE",
        "SANDBOX_DONE_QUEUE",
        "GRADER_MODEL",
        "GRADER_CONCURRENCY",
        "GRADER_VERIFIER_ENABLED",
        "GRADER_SHADOW",
        "GRADER_REVIEW_DIVERGENCE_THRESHOLD",
        "GRADER_LOW_CONF_THRESHOLD",
        "TRANSCRIBE_POLL_INTERVAL_MS",
        "TRANSCRIBE_TIMEOUT_MS",
        "SANDBOX_QUEUE",
        "SANDBOX_CONCURRENCY",
        "SANDBOX_IMAGE",
        "SANDBOX_RUNTIME",
        "SANDBOX_SECCOMP_PATH",
        "OUTBOX_INTERVAL_MS",
        "DATABASE_POOL_MAX",
        "MEMO_MODEL",
        "MCP_PORT",
        "CANDIDATEASSESSMENT_*"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "typecheck": { "dependsOn": ["^build"] },
    "clean": { "cache": false }
  }
}
